# MongoDB connection
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=test

# Server
PORT=15240
HOST=0.0.0.0
NODE_ENV=development

# JWT secret for RBAC
JWT_SECRET=your-super-secret-jwt-token-change-in-production

# RBAC configuration file path (YAML)
RBAC_CONFIG_PATH=./src/shared/config/rbac.yaml

# Logging
LOG_LEVEL=info